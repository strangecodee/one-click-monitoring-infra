global:
  resolve_timeout: 5m

route:
  receiver: 'default'
  group_by: ['alertname']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 1h

receivers:
  - name: 'default'
{% if alertmanager_slack_webhook_url %}
    slack_configs:
      - api_url: '{{ alertmanager_slack_webhook_url }}'
        channel: '#jenkins-alerts'
        send_resolved: true
        title: '[{% raw %}{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}{% endraw %}] Monitoring Alert'
        text: >-
          {% raw %}{{ range .Alerts -}}
          *Alert:* {{ .Annotations.summary }} - {{ .Labels.severity }}
          *Description:* {{ .Annotations.description }}
          *Details:*
            {{ range .Labels.SortedPairs }}• *{{ .Name }}:* `{{ .Value }}`
            {{ end }}
          {{ end }}{% endraw %}
{% else %}
    webhook_configs:
      - url: 'http://localhost:9090'
{% endif %}
