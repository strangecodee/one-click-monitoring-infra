#!/usr/bin/env python3
import time
import random
import os

panels = ["Logs", "Time Series", "Gauge", "Pie Chart", "Table", "Activity Heatmap"]
users = ["annuexe", "admin", "viewer", "dashboard_owner"]
sources = [
    "grafanacloud-punymuffin1662-usage-insights",
    "prometheus",
    "loki",
    "alertmanager"
]

log_file = "/var/log/grafana_mock.log"

# Ensure the log file exists and is writable
if not os.path.exists(log_file):
    with open(log_file, "w") as f:
        pass
    os.chmod(log_file, 0o666)

with open(log_file, "a") as f:
    while True:
        panel = random.choice(panels)
        user = random.choice(users)
        src = random.choice(sources)
        duration = random.randint(50, 600)
        line = f'level=info eventName="data-request" panelName="{panel}" username="{user}" datasourceName="{src}" duration={duration} service_name="grafana"\n'
        f.write(line)
        f.flush()
        time.sleep(random.uniform(2.0, 5.0))
